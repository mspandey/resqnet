# ResQNet — Environment Variables
# Copy this file to infra/.env and fill in real values before running docker-compose.
# NEVER commit infra/.env to version control.

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=resqnet
POSTGRES_PASSWORD=resqnet
POSTGRES_DB=resqnet

# ── App environment ───────────────────────────────────────────────────────────
# development | production
ENVIRONMENT=development

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the API Gateway
ALLOWED_ORIGINS=http://localhost:3000

# ── AI / LLM ─────────────────────────────────────────────────────────────────
# Provider: groq | together | openai
LLM_PROVIDER=groq
LLM_API_KEY=
# Model name as understood by the chosen provider
LLM_MODEL=llama3-70b-8192
# model_version logged on every Classification row (RULES.md §3 — non-negotiable)
MODEL_VERSION=llama3-70b-8192:resqnet-v1.0

# ── Deduplication ─────────────────────────────────────────────────────────────
# Cosine similarity threshold (0.0–1.0); 0.92 is the MVP default (TECHSPEC §6)
DEDUP_SIMILARITY_THRESHOLD=0.92

# ── Twilio (SMS fallback — Phase 3; leave blank in Phase 1) ───────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Firebase (push notifications — Phase 2+) ──────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Escape newlines in the private key: replace actual \n with \\n
FIREBASE_PRIVATE_KEY=

# ── Object Storage (signed media URLs — Phase 2+) ────────────────────────────
# Base URL for the object storage service (e.g. MinIO for local, GCS for prod)
STORAGE_BASE_URL=http://localhost:9000

# ── Frontend ─────────────────────────────────────────────────────────────────
# Mapbox public token (safe to commit once restricted to your domain)
NEXT_PUBLIC_MAPBOX_TOKEN=

# Allowed web origin for Socket.IO CORS
WEB_ORIGIN=http://localhost:3000
